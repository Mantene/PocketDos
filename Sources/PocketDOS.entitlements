<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Raises the app process's jetsam limit on supported devices. Helps native
         memory headroom; effect on the WKWebView WebContent process is uncertain
         (separate system process) — included as a low-cost experiment for Win9x. -->
    <key>com.apple.developer.kernel.increased-memory-limit</key>
    <true/>
    <!-- iCloud Documents sync for per-game save deltas (SPEC H46). The container
         must be created + the iCloud capability enabled on the signing account;
         the app gracefully no-ops (local-only) when iCloud is unavailable. -->
    <key>com.apple.developer.icloud-services</key>
    <array>
        <string>CloudDocuments</string>
    </array>
    <key>com.apple.developer.icloud-container-identifiers</key>
    <array>
        <string>iCloud.com.mantene.PocketDOS</string>
    </array>
    <key>com.apple.developer.ubiquity-container-identifiers</key>
    <array>
        <string>iCloud.com.mantene.PocketDOS</string>
    </array>
</dict>
</plist>
