<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDisplayName</key>
    <string>PocketDOS</string>
    <key>CFBundleName</key>
    <string>PocketDOS</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <!-- Explicit device requirement (App Review 2026-07-14, guideline 2.3): declare only
         arm64 — present on EVERY supported device, including the iPad review device (iPad
         Air M3) — so this iPhone-only app installs in compatibility mode on iPad. The v1.0(2)
         rejection was "UIRequiredDeviceCapabilities … will not install on the review device";
         our source never set this key, so the App Store's auto-added value was the blocker.
         Declaring arm64 explicitly satisfies Apple's remedy and is installable everywhere. -->
    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>arm64</string>
    </array>
    <key>UILaunchScreen</key>
    <dict/>
    <!-- Not-for-profit, no encryption beyond OS-exempt -->
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>
    <!-- Expose the app's Documents (games library) in the Files app so users can
         add/manage/back-up games directly (Documents/Games/...). -->
    <key>UIFileSharingEnabled</key>
    <true/>
    <key>LSSupportsOpeningDocumentsInPlace</key>
    <true/>
    <!-- All orientations declared (Apple is making this mandatory; UIRequiresFullScreen
         is deprecated and was removed). Gameplay still locks to landscape at RUNTIME via
         AppDelegate.application(_:supportedInterfaceOrientationsFor:), which is allowed. -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <!-- Let games open INTO PocketDOS from Files / share sheets ("Open in PocketDOS").
         A second import path independent of the in-app picker. Rank "Alternate" so we
         offer to handle .zip without hijacking it as the system default. -->
    <key>CFBundleDocumentTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeName</key>
            <string>DOS/Win9x game bundle</string>
            <key>LSHandlerRank</key>
            <string>Alternate</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>com.mantene.jsdos</string>
                <string>public.zip-archive</string>
            </array>
        </dict>
    </array>
    <!-- .jsdos is a zip with a .jsdos/ manifest; declare it so the system recognizes the extension. -->
    <key>UTImportedTypeDeclarations</key>
    <array>
        <dict>
            <key>UTTypeIdentifier</key>
            <string>com.mantene.jsdos</string>
            <key>UTTypeDescription</key>
            <string>js-dos game bundle</string>
            <key>UTTypeConformsTo</key>
            <array>
                <string>public.zip-archive</string>
            </array>
            <key>UTTypeTagSpecification</key>
            <dict>
                <key>public.filename-extension</key>
                <array>
                    <string>jsdos</string>
                </array>
            </dict>
        </dict>
    </array>
</dict>
</plist>
