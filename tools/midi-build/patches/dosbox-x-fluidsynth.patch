diff --git a/include/fluidsynth/config_emscripten.h b/include/fluidsynth/config_emscripten.h
new file mode 100644
index 000000000..72ae18ea1
--- /dev/null
+++ b/include/fluidsynth/config_emscripten.h
@@ -0,0 +1,66 @@
+/* FluidSynth build config for Emscripten / WebAssembly (POSIX-like).
+ *
+ * Added for the PocketDOS General-MIDI build: the bundled DOSBox-X FluidSynth
+ * only shipped a Windows config (config_win32.h), which forces <io.h>,
+ * <windows.h> and a conflicting `typedef int socklen_t`. Under Emscripten we
+ * want a POSIX configuration with no Windows headers, no networking server,
+ * and no platform audio driver (DOSBox-X pulls samples directly via
+ * fluid_synth_write_s16, so no fluid audio driver is needed). */
+
+#ifndef _CONFIG_EMSCRIPTEN_H
+#define _CONFIG_EMSCRIPTEN_H
+
+#define FLUIDSYNTHVERSION "2.x-jsdos"
+
+/* On Windows these came from <windows.h>; the bundled fluid sources rely on
+ * them. Provide them for the POSIX/Emscripten build (no other header defines
+ * TRUE/FALSE/boolean in this tree). */
+#ifndef TRUE
+#define TRUE 1
+#endif
+#ifndef FALSE
+#define FALSE 0
+#endif
+typedef int boolean;
+
+/* Headers available under the Emscripten musl sysroot. */
+#define HAVE_STRING_H 1
+#define HAVE_STDLIB_H 1
+#define HAVE_STDIO_H 1
+#define HAVE_MATH_H 1
+#define HAVE_ERRNO_H 1
+#define HAVE_STDARG_H 1
+#define HAVE_UNISTD_H 1
+#define HAVE_FCNTL_H 1
+#define HAVE_SYS_TYPES_H 1
+#define HAVE_SYS_STAT_H 1
+#define HAVE_SYS_TIME_H 1
+#define HAVE_LIMITS_H 1
+/* fluid_sys.c compiles its socket server helper unconditionally; Emscripten's
+ * musl provides these POSIX socket headers (the server is never started). */
+#define HAVE_SYS_SOCKET_H 1
+#define HAVE_NETINET_IN_H 1
+#define HAVE_NETINET_TCP_H 1
+#define HAVE_ARPA_INET_H 1
+
+/* Deliberately NOT defined: HAVE_IO_H, HAVE_WINDOWS_H (Windows-only),
+ * HAVE_SYS_SOCKET_H / HAVE_NETINET_IN_H / HAVE_PTHREAD_H (server + threads
+ * unused; this WASM build is single-threaded). Leaving socklen_t alone so it
+ * matches the Emscripten sysroot definition. */
+
+/* Threading abstraction: Emscripten provides <pthread.h> (functional stubs even
+ * in single-threaded builds), so route fluid_mutex.h / fluid_sys.h to the
+ * pthread path instead of the Windows path. */
+#define HAVE_PTHREAD_H 1
+
+#define WITHOUT_SERVER 1
+#define SDL2_SUPPORT 0
+#define DSOUND_SUPPORT 0
+#define WINMIDI_SUPPORT 0
+#define AUFILE_SUPPORT 0
+#define WITH_FLOAT 1
+#define WITH_PROFILING 0
+
+#define DEFAULT_SOUNDFONT "TIMGM6MB.SF2"
+
+#endif /* _CONFIG_EMSCRIPTEN_H */
