+#endif /* __EMSCRIPTEN__ */
diff --git a/src/hardware/imfc.cpp b/src/hardware/imfc.cpp
index 17bfcf194..ddc3c6e33 100644
--- a/src/hardware/imfc.cpp
+++ b/src/hardware/imfc.cpp
@@ -795,6 +795,7 @@ static_assert(sizeof(OperatorDefinition) == 8,
               "OperatorDefinition needs to be 8 in size!");
 
 struct VoiceDefinition {
+	VoiceDefinition();   // PocketDOS: strong out-of-line def (clang -Oz drops the implicit one)
 private:
 	// clang-format off
 	// +00~+06: Name of instrument
@@ -1299,6 +1300,7 @@ static_assert(sizeof(ConfigurationData) == 0xA0,
 struct YmChannelData; // forward declaration
 
 struct InstrumentParameters {
+	InstrumentParameters();   // PocketDOS: strong out-of-line def (clang -Oz drops the implicit one)
 private:
 	InstrumentParameters& operator=(const InstrumentParameters& other)
 	{ /* don't use */
@@ -1378,6 +1380,7 @@ public:
 };
 
 struct YmChannelData {
+	YmChannelData();   // PocketDOS: strong out-of-line def (clang -Oz drops the implicit one)
 private:
 	YmChannelData& operator=(const YmChannelData& other)
 	{ /* don't use */
@@ -13062,3 +13065,10 @@ void IMFC_Init()
 	}
 	AddExitFunction(AddExitFunctionFuncPair(IMFC_ShutDown), true);
 }
+
+// PocketDOS: explicit out-of-line default constructors. clang at -Oz leaves the
+// implicit (linkonce_odr) versions of these as undefined references from the
+// `= {}` member arrays; defining them out-of-line here emits strong symbols.
+VoiceDefinition::VoiceDefinition() = default;
+InstrumentParameters::InstrumentParameters() = default;
+YmChannelData::YmChannelData() = default;
