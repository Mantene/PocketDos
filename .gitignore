# Xcode / build
build/
DerivedData/
*.xcuserstate
xcuserdata/
.DS_Store

# oh-my-claudecode / tooling state
.omc/

# Generated by XcodeGen — commit project.yml, not the project.
*.xcodeproj

# js-dos assets are synced from a js-dos build via scripts/sync-jsdos.sh.
# They are committed for the spike so the app runs without a Node toolchain;
# if you prefer to keep the repo lean, uncomment the lines below and run the
# sync script after cloning.
# Web/js-dos.js
# Web/js-dos.css
# Web/emulators/

# User-provided game content (never commit copyrighted games)
Web/games/*
!Web/games/.gitkeep

# Backup of the stock js-dos wdosbox-x assets (kept locally before swapping in
# the custom FluidSynth build); recoverable from js-dos, not worth committing.
Web/emulators/.orig-backup/
